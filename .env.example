# Cl√© secr√®te Stripe ‚Äî Dashboard > Developers > API keys.
# Utilisez une cl√© "sk_test_..." tant que vous √™tes en d√©veloppement.
# NE JAMAIS committer le fichier .env une fois renomm√© (voir .gitignore).
STRIPE_SECRET_KEY=sk_test_votre_cle_secrete

# Secret de signature du webhook ‚Äî Dashboard > Developers > Webhooks > votre
# endpoint, ou affich√© par `stripe listen` en local (voir README.md).
STRIPE_WEBHOOK_SECRET=whsec_votre_secret_webhook

# URL publique de votre frontend une fois d√©ploy√© (sert √† construire les
# success_url / cancel_url / return_url, et pour la config CORS).
APP_URL=https://atchef.fr

# Port d'√©coute du serveur backend en local.
PORT=4242

# Adresse de connexion √† votre base PostgreSQL (persistante, contrairement
# √† l'ancienne version en m√©moire). Avec Supabase (gratuit, sans limite de
